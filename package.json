{
  "name": "whatsapp-broadcaster",
  "version": "1.1.0",
  "description": "WhatsApp Group Broadcaster",
  "main": "core/server.js",
  "scripts": {
    "start": "node core/server.js",
    "dev": "concurrently \"node core/server.js\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "prepare": "husky",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "nodemailer": "^6.9.13",
    "puppeteer": "^22.6.5",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "standard-version": "^9.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
